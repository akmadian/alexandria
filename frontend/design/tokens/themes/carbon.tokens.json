{
  "$description": "Carbon (§21, anchor L 0.215). Ramp ratified 2026-07-12; C=0 exactly. Dark world: chrome raises; transient is a real raised step (§6).",

  "surface": {
    "$type": "color",
    "panel": { "$value": { "colorSpace": "oklch", "components": [0.215, 0, 0] } },
    "field": { "$value": { "colorSpace": "oklch", "components": [0.19, 0, 0] } },
    "hover": { "$value": { "colorSpace": "oklch", "components": [0.245, 0, 0] } },
    "pressed": { "$value": { "colorSpace": "oklch", "components": [0.265, 0, 0] } },
    "selected": { "$value": { "colorSpace": "oklch", "components": [0.32, 0, 0] }, "$extensions": { "alx": { "role": "+2 register steps (2026-07-13)" } } },
    "transient": { "$value": { "colorSpace": "oklch", "components": [0.26, 0, 0] }, "$extensions": { "alx": { "role": "raised above panel (§6)" } } }
  },

  "cell": {
    "$type": "color",
    "well": { "$value": { "colorSpace": "oklch", "components": [0.17, 0, 0] } },
    "rest": { "$value": { "colorSpace": "oklch", "components": [0.21, 0, 0] } },
    "hover": { "$value": { "colorSpace": "oklch", "components": [0.245, 0, 0] } },
    "selected": { "$value": { "colorSpace": "oklch", "components": [0.285, 0, 0] } },
    "active": { "$value": { "colorSpace": "oklch", "components": [0.335, 0, 0] }, "$extensions": { "alx": { "role": "family ceiling" } } }
  },

  "ink": {
    "$type": "color",
    "1": { "$value": { "colorSpace": "oklch", "components": [0.9, 0, 0] } },
    "2": { "$value": { "colorSpace": "oklch", "components": [0.74, 0, 0] }, "$extensions": { "alx": { "role": "retuned 2026-07-13 (was 0.785) — see graphite ink.2" } } },
    "3": { "$value": { "colorSpace": "oklch", "components": [0.635, 0, 0] }, "$extensions": { "alx": { "role": "retuned with ink.2 (was 0.665)" } } },
    "4": { "$value": { "colorSpace": "oklch", "components": [0.56, 0, 0] } },
    "hairline": { "$value": { "colorSpace": "oklch", "components": [0.32, 0, 0] } }
  }
}
