    "register-step": { "$type": "number", "$value": 0.035, "$extensions": { "alx": { "role": "the dark-world register quantum (ratified 2026-07-13); see hues-light for the doctrine — dark polarity needs roughly double the light step for the same felt change." } } }
  },

