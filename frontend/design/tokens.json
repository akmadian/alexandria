{
  "$description": "Alexandria design tokens — THE source of truth (docs/design-constitution.md §22). W3C DTCG-shaped. Semantic roles only; components consume the generated CSS variables, never these values directly. $extensions.alx.pin: 'hypothesis' marks values awaiting the §30 pinning gates. CSS var naming: theme.<t>.<group>.<name> → --alx-<group>-<name> scoped per theme; top-level groups → :root.",

  "family": {
    "$description": "Register-shift direction declarations (§7). The validator checks per-family monotonicity in the declared direction.",
    "chrome": { "direction": { "paper": "recess", "linen": "recess", "graphite": "raise", "carbon": "raise" } },
    "cell": { "direction": { "paper": "raise", "linen": "raise", "graphite": "raise", "carbon": "raise" } }
  },

  "theme": {
    "paper": {
      "$description": "Default theme (§21).",
      "surface": {
        "panel": { "$type": "color", "$value": "oklch(0.975 0 0)", "$extensions": { "alx": { "pin": "hypothesis", "role": "rails, inspector, bars, popovers" } } },
        "field": { "$type": "color", "$value": "oklch(0.955 0 0)", "$extensions": { "alx": { "role": "input wells (recessed)" } } },
        "hover": { "$type": "color", "$value": "oklch(0.952 0 0)", "$extensions": { "alx": { "role": "row/control hover fill" } } },
        "pressed": { "$type": "color", "$value": "oklch(0.938 0 0)" },
        "selected": { "$type": "color", "$value": "oklch(0.93 0 0)", "$extensions": { "alx": { "role": "selected row/chip fill" } } }
      },
      "cell": {
        "well": { "$type": "color", "$value": "oklch(0.955 0 0)", "$extensions": { "alx": { "pin": "hypothesis", "role": "grid well (family base; §20)" } } },
        "rest": { "$type": "color", "$value": "oklch(0.972 0 0)" },
        "hover": { "$type": "color", "$value": "oklch(0.984 0 0)" },
        "selected": { "$type": "color", "$value": "oklch(0.993 0 0)" },
        "active": { "$type": "color", "$value": "oklch(1 0 0)", "$extensions": { "alx": { "role": "family ceiling + 1px ink frame (§20)" } } }
      },
      "ink": {
        "1": { "$type": "color", "$value": "oklch(0.25 0.005 275)", "$extensions": { "alx": { "role": "primary: values, names" } } },
        "2": { "$type": "color", "$value": "oklch(0.42 0.005 275)", "$extensions": { "alx": { "role": "secondary: labels" } } },
        "3": { "$type": "color", "$value": "oklch(0.56 0.005 275)", "$extensions": { "alx": { "role": "muted: placeholders, counts" } } },
        "4": { "$type": "color", "$value": "oklch(0.68 0.003 275)", "$extensions": { "alx": { "role": "disabled" } } },
        "hairline": { "$type": "color", "$value": "oklch(0.885 0.002 275)", "$extensions": { "alx": { "role": "seams, separators (§3)" } } }
      }
    },
    "linen": {
      "surface": {
        "panel": { "$type": "color", "$value": "oklch(0.905 0 0)", "$extensions": { "alx": { "pin": "hypothesis" } } },
        "field": { "$type": "color", "$value": "oklch(0.878 0 0)" },
        "hover": { "$type": "color", "$value": "oklch(0.875 0 0)" },
        "pressed": { "$type": "color", "$value": "oklch(0.858 0 0)" },
        "selected": { "$type": "color", "$value": "oklch(0.85 0 0)" }
      },
      "cell": {
        "well": { "$type": "color", "$value": "oklch(0.878 0 0)" },
        "rest": { "$type": "color", "$value": "oklch(0.902 0 0)" },
        "hover": { "$type": "color", "$value": "oklch(0.92 0 0)" },
        "selected": { "$type": "color", "$value": "oklch(0.938 0 0)" },
        "active": { "$type": "color", "$value": "oklch(0.958 0 0)" }
      },
      "ink": {
        "1": { "$type": "color", "$value": "oklch(0.23 0.005 275)" },
        "2": { "$type": "color", "$value": "oklch(0.39 0.005 275)" },
        "3": { "$type": "color", "$value": "oklch(0.52 0.005 275)" },
        "4": { "$type": "color", "$value": "oklch(0.63 0.003 275)" },
        "hairline": { "$type": "color", "$value": "oklch(0.80 0.002 275)" }
      }
    },
    "graphite": {
      "surface": {
        "panel": { "$type": "color", "$value": "oklch(0.30 0.004 275)", "$extensions": { "alx": { "pin": "hypothesis" } } },
        "field": { "$type": "color", "$value": "oklch(0.27 0.004 275)" },
        "hover": { "$type": "color", "$value": "oklch(0.33 0.004 275)" },
        "pressed": { "$type": "color", "$value": "oklch(0.35 0.004 275)" },
        "selected": { "$type": "color", "$value": "oklch(0.365 0.004 275)" }
      },
      "cell": {
        "well": { "$type": "color", "$value": "oklch(0.26 0.004 275)" },
        "rest": { "$type": "color", "$value": "oklch(0.30 0.004 275)" },
        "hover": { "$type": "color", "$value": "oklch(0.335 0.004 275)" },
        "selected": { "$type": "color", "$value": "oklch(0.375 0.004 275)" },
        "active": { "$type": "color", "$value": "oklch(0.42 0.004 275)" }
      },
      "ink": {
        "1": { "$type": "color", "$value": "oklch(0.93 0.003 275)" },
        "2": { "$type": "color", "$value": "oklch(0.80 0.003 275)" },
        "3": { "$type": "color", "$value": "oklch(0.685 0.003 275)" },
        "4": { "$type": "color", "$value": "oklch(0.585 0.003 275)" },
        "hairline": { "$type": "color", "$value": "oklch(0.40 0.003 275)" }
      }
    },
    "carbon": {
      "surface": {
        "panel": { "$type": "color", "$value": "oklch(0.215 0.004 275)", "$extensions": { "alx": { "pin": "hypothesis" } } },
        "field": { "$type": "color", "$value": "oklch(0.185 0.004 275)" },
        "hover": { "$type": "color", "$value": "oklch(0.245 0.004 275)" },
        "pressed": { "$type": "color", "$value": "oklch(0.265 0.004 275)" },
        "selected": { "$type": "color", "$value": "oklch(0.28 0.004 275)" }
      },
      "cell": {
        "well": { "$type": "color", "$value": "oklch(0.17 0.004 275)" },
        "rest": { "$type": "color", "$value": "oklch(0.21 0.004 275)" },
        "hover": { "$type": "color", "$value": "oklch(0.245 0.004 275)" },
        "selected": { "$type": "color", "$value": "oklch(0.285 0.004 275)" },
        "active": { "$type": "color", "$value": "oklch(0.335 0.004 275)" }
      },
      "ink": {
        "1": { "$type": "color", "$value": "oklch(0.90 0.003 275)" },
        "2": { "$type": "color", "$value": "oklch(0.785 0.003 275)" },
        "3": { "$type": "color", "$value": "oklch(0.665 0.003 275)" },
        "4": { "$type": "color", "$value": "oklch(0.56 0.003 275)" },
        "hairline": { "$type": "color", "$value": "oklch(0.32 0.003 275)" }
      }
    }
  },

  "stage": {
    "$description": "Theme-independent asset surround (§1). User-adjustable within range.",
    "default": { "$type": "color", "$value": "oklch(0.34 0 0)", "$extensions": { "alx": { "pin": "hypothesis" } } },
    "min": { "$type": "color", "$value": "oklch(0.20 0 0)" },
    "max": { "$type": "color", "$value": "oklch(0.50 0 0)" }
  },

  "hue": {
    "$description": "The hue ledger (§5) — the EXHAUSTIVE list of chroma in chrome.",
    "accent": {
      "$type": "color", "$value": "oklch(0.56 0.12 205)",
      "$extensions": { "alx": { "pin": "hypothesis — THE open decision (§30.1)", "candidates": ["oklch(0.56 0.12 205)", "oklch(0.55 0.15 235)", "oklch(0.56 0.16 345)", "oklch(0.58 0.13 165)"] } }
    },
    "attention": { "$type": "color", "$value": "oklch(0.62 0.14 315)", "$extensions": { "alx": { "pin": "hypothesis default; user-picked from tag palette at runtime (§29)" } } },
    "error": { "$type": "color", "$value": "oklch(0.55 0.19 27)", "$extensions": { "alx": { "role": "invalid input only (§25); independent of attention" } } },
    "label": {
      "$description": "LrC-compatible color labels; user-toggleable off (§5).",
      "red": { "$type": "color", "$value": "oklch(0.55 0.18 25)" },
      "yellow": { "$type": "color", "$value": "oklch(0.76 0.15 95)" },
      "green": { "$type": "color", "$value": "oklch(0.60 0.15 145)" },
      "blue": { "$type": "color", "$value": "oklch(0.55 0.15 255)" },
      "purple": { "$type": "color", "$value": "oklch(0.55 0.15 305)" }
    },
    "tag": {
      "$description": "The engineered tag palette: 12 hues, fixed L/C per world (§5). Users pick from these only.",
      "hues": [15, 45, 75, 105, 135, 165, 195, 225, 255, 285, 315, 345],
      "light": { "lightness": 0.62, "chroma": 0.12 },
      "dark": { "lightness": 0.72, "chroma": 0.12 },
      "tintAlpha": 0.14,
      "$extensions": { "alx": { "pin": "hypothesis" } }
    },
    "light-register": {
      "$description": "Polychrome light — hero register only (§17).",
      "gradient": { "$type": "color", "$value": "linear-gradient(100deg, oklch(0.72 0.16 15), oklch(0.80 0.14 95), oklch(0.72 0.14 165), oklch(0.68 0.14 255), oklch(0.70 0.15 315), oklch(0.72 0.16 15))" },
      "flow-duration": { "$type": "duration", "$value": "7000ms" },
      "glass-blur": { "$type": "dimension", "$value": "14px" },
      "glass-saturate": { "$value": 1.3 },
      "glass-face-alpha": { "$value": 0.5 }
    }
  },

  "type": {
    "$description": "§9. px-locked; hierarchy by weight + ink, never size within a surface. Windows 11px check pending (§28).",
    "family": {
      "sans": { "$type": "fontFamily", "$value": "Geist, system-ui, sans-serif" },
      "mono": { "$type": "fontFamily", "$value": "'Geist Mono', ui-monospace, monospace" },
      "joy-serif": { "$type": "fontFamily", "$value": "'Instrument Serif', serif", "$extensions": { "alx": { "role": "joy register ONLY (§16)" } } },
      "joy-pixel": { "$type": "fontFamily", "$value": "'Geist Pixel', monospace", "$extensions": { "alx": { "role": "dot voice in type; rarest register" } } }
    },
    "scale": {
      "ui-11": { "size": "11px", "lineHeight": "16px", "tracking": "0.01em", "$extensions": { "alx": { "pin": "hypothesis", "role": "dense metadata, counts, cell captions" } } },
      "ui-12": { "size": "12px", "lineHeight": "16px", "tracking": "0.005em", "$extensions": { "alx": { "role": "default row/control text" } } },
      "ui-13": { "size": "13px", "lineHeight": "20px", "tracking": "0em", "$extensions": { "alx": { "role": "section heads (sentence-case bold), dialogs" } } }
    },
    "weight": { "regular": 400, "medium": 500, "semibold": 600 }
  },

  "layout": {
    "$description": "§8. Quantum 4px; two control heights; uniform row rhythm.",
    "quantum": { "$type": "dimension", "$value": "4px" },
    "control-sm": { "$type": "dimension", "$value": "24px", "$extensions": { "alx": { "pin": "hypothesis" } } },
    "control-md": { "$type": "dimension", "$value": "28px" },
    "row": { "$type": "dimension", "$value": "28px", "$extensions": { "alx": { "role": "tree + inspector row height" } } },
    "row-inset": { "$type": "dimension", "$value": "12px", "$extensions": { "alx": { "role": "horizontal generosity: identical side insets, text never touches an edge" } } },
    "icon": { "$type": "dimension", "$value": "16px" },
    "icon-stroke": { "$type": "dimension", "$value": "1.5px", "$extensions": { "alx": { "pin": "hypothesis (§14)" } } },
    "hit-target": { "$type": "dimension", "$value": "24px" },
    "panel-left": { "default": "260px", "min": "200px" },
    "panel-right": { "default": "300px", "min": "240px" },
    "cell-pad": { "$type": "dimension", "$value": "8px", "$extensions": { "alx": { "role": "interior cell padding — photos never touch (§19)" } } },
    "thumb-hairline-alpha": { "$value": 0.07, "$extensions": { "alx": { "role": "1px inner border on thumbnails (§19)" } } }
  },

  "radius": {
    "$description": "Radius by detachment (§24): docked 0 → controls small → transients large.",
    "docked": { "$type": "dimension", "$value": "0px" },
    "control": { "$type": "dimension", "$value": "4px", "$extensions": { "alx": { "pin": "hypothesis" } } },
    "transient": { "$type": "dimension", "$value": "8px" },
    "round": { "$type": "dimension", "$value": "999px" }
  },

  "z": {
    "$description": "The z-order registry (§24). There is no other elevation.",
    "docked": 0, "tunnel": 1, "transient": 100, "dialog": 200, "toast": 300
  },

  "shadow": {
    "$description": "Exactly two recipes (§6).",
    "occlusion": { "$type": "shadow", "$value": "0 4px 16px oklch(0 0 0 / 0.16), 0 1px 3px oklch(0 0 0 / 0.10)" },
    "tunnel": { "$type": "shadow", "$value": "inset 0 6px 8px -6px oklch(0 0 0 / 0.25)", "$extensions": { "alx": { "role": "scroll-linked, cast inward onto clipped content only" } } }
  },

  "motion": {
    "$description": "§26. Register shifts ≤ fast; transients base; the one hero transition slow.",
    "duration": {
      "fast": { "$type": "duration", "$value": "80ms" },
      "base": { "$type": "duration", "$value": "160ms" },
      "slow": { "$type": "duration", "$value": "240ms" }
    },
    "easing": {
      "out": { "$type": "cubicBezier", "$value": "cubic-bezier(0.16, 1, 0.3, 1)" },
      "in-out": { "$type": "cubicBezier", "$value": "cubic-bezier(0.65, 0, 0.35, 1)" }
    }
  },

  "focus": {
    "ring-width": { "$type": "dimension", "$value": "2px" },
    "ring-offset": { "$type": "dimension", "$value": "1px" }
  },

  "machinery": {
    "$description": "Domain state → dot-matrix loader mapping (§14; source: dot-matrix-animations.vercel.app). Loader ids PIN pending selection from the library.",
    "map": [
      { "state": "ingesting", "category": "progress", "loader": "PIN" },
      { "state": "thumbnail-generating", "category": "spinner", "loader": "pulse-rings" },
      { "state": "preview-building", "category": "spinner", "loader": "PIN" },
      { "state": "watcher-ambient", "category": "ambient", "loader": "PIN" },
      { "state": "reconciler-working", "category": "agent", "loader": "PIN" },
      { "state": "sync-pending", "category": "status", "loader": "PIN" },
      { "state": "import-session-marquee", "category": "progress", "loader": "light-bar (§17, not a dot loader)" }
    ]
  },

  "contracts": {
    "$description": "§23 — what the validator (and the library's live readouts) verify. minLc per APCA-W3, checked per theme.",
    "text": [
      { "ink": "ink.1", "on": ["surface.panel", "surface.field", "cell.rest", "cell.active"], "minLc": 75 },
      { "ink": "ink.2", "on": ["surface.panel", "surface.field"], "minLc": 60 },
      { "ink": "ink.3", "on": ["surface.panel"], "minLc": 40 },
      { "ink": "ink.4", "on": ["surface.panel"], "minLc": 25 }
    ],
    "separation": [
      { "pair": ["ink.hairline", "surface.panel"], "deltaL": [0.05, 0.14], "$comment": "seams: visible but quiet" },
      { "pair": ["surface.hover", "surface.panel"], "deltaL": [0.012, 0.06], "$comment": "register step: just above threshold (APCA clamps sub-threshold to 0, so ΔL is the instrument here)" },
      { "pair": ["cell.rest", "cell.well"], "deltaL": [0.012, 0.06] }
    ],
    "structure": [
      "per-family monotonic in declared direction",
      "every dimension a quantum multiple",
      "attention hue ≠ any enabled label hue",
      "chrome chroma ≈ 0 outside the ledger"
    ]
  }
}
