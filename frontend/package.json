{
    "name": "alexandria-frontend",
    "version": "0.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage",
        "lint": "eslint src design/compiler",
        "lint:css": "stylelint \"src/**/*.css\"",
        "typecheck": "tsc -b --noEmit",
        "generate:tokens": "bun design/compiler/main.ts",
        "check": "bun run generate:tokens && git diff --exit-code --quiet -- src/styles/tokens.css src/styles/tokens.ts src/styles/tokens-reference.json && tsc -b --noEmit && eslint src design/compiler && stylelint \"src/**/*.css\" && vitest run",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.101.2",
        "@tanstack/react-virtual": "^3.14.5",
        "geist": "^1.7.2",
        "i18next": "^26.3.4",
        "lucide-react": "^1.23.0",
        "react": "^19.2.4",
        "react-aria": "^3.50.0",
        "react-aria-components": "^1.19.0",
        "react-dom": "^19.2.4",
        "react-i18next": "^17.0.8",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@eslint/js": "^9",
        "@storybook/addon-a11y": "^10.5.3",
        "@storybook/addon-docs": "^10.5.3",
        "@storybook/addon-mcp": "^0.7.0",
        "@storybook/react-vite": "^10.5.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/culori": "^4.0.1",
        "@types/node": "^26.1.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.9",
        "apca-w3": "^0.1.9",
        "culori": "^4.0.2",
        "eslint": "^9",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-storybook": "^10.5.3",
        "globals": "^17.7.0",
        "happy-dom": "^20.10.6",
        "prettier": "^3.8.1",
        "storybook": "^10.5.3",
        "stylelint": "^17.14.0",
        "stylelint-declaration-strict-value": "^1.11.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.53.1",
        "vite": "^8.0.2",
        "vite-plugin-stylelint": "^6.3.0",
        "vitest": "^4.1.9"
    }
}
